      },
      {
        "type": "graph",
        "title": "Open Positions",
        "targets": [ { "expr": "mtb_open_positions", "legendFormat": "open_positions" } ],
        "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 }
      },
      {
        "type": "graph",
        "title": "Market Data Fetches",
        "targets": [ { "expr": "increase(mtb_md_fetches_total[5m])", "legendFormat": "md_fetches" } ],
        "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 }
      }
    ],
